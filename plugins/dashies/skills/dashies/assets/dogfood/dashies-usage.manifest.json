{
  "manifest_version": 1,
  "connection": "self",
  "schedule": "daily",
  "cube_sql": "select day, dashboards_published, public_count, private_count, active_count, paused_count, failed_count, archived_count, scheduled_count from public.dashies_usage_metrics where day >= (now() - interval '90 days')::date order by day",
  "dimensions": [
    {
      "key": "day",
      "label": "Day",
      "type": "date"
    }
  ],
  "measures": [
    {
      "key": "dashboards_published",
      "label": "Published",
      "agg": "sum",
      "additive": true,
      "format": "integer"
    },
    {
      "key": "public_count",
      "label": "Public",
      "agg": "sum",
      "additive": true,
      "format": "integer"
    },
    {
      "key": "private_count",
      "label": "Private",
      "agg": "sum",
      "additive": true,
      "format": "integer"
    },
    {
      "key": "active_count",
      "label": "Active",
      "agg": "sum",
      "additive": true,
      "format": "integer"
    },
    {
      "key": "paused_count",
      "label": "Paused",
      "agg": "sum",
      "additive": true,
      "format": "integer"
    },
    {
      "key": "failed_count",
      "label": "Failed",
      "agg": "sum",
      "additive": true,
      "format": "integer"
    },
    {
      "key": "archived_count",
      "label": "Archived",
      "agg": "sum",
      "additive": true,
      "format": "integer"
    },
    {
      "key": "scheduled_count",
      "label": "Scheduled",
      "agg": "sum",
      "additive": true,
      "format": "integer"
    }
  ],
  "derived": [
    {
      "label": "Public share",
      "kind": "ratio",
      "num": "public_count",
      "den": "dashboards_published",
      "format": "percent"
    },
    {
      "label": "Scheduled share",
      "kind": "ratio",
      "num": "scheduled_count",
      "den": "dashboards_published",
      "format": "percent"
    }
  ]
}
